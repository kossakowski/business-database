# Database Configuration
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit the .env file to version control!

# PostgreSQL Database Settings
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
POSTGRES_DB=lawfirm
POSTGRES_PORT=5432

# Application Database URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://admin:CHANGE_ME_TO_STRONG_PASSWORD@localhost:5432/lawfirm

# Registry API Configuration (Optional)
# Get CEIDG token from https://dane.biznes.gov.pl
CEIDG_API_TOKEN=your_token_here
CEIDG_API_BASE_URL=https://dane.biznes.gov.pl/api/ceidg/v3
CEIDG_REQUEST_TIMEOUT=30

# KRS API Configuration (Optional, uses public API)
KRS_API_BASE_URL=https://api-krs.ms.gov.pl/api/krs
KRS_REQUEST_TIMEOUT=30
